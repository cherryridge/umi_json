{
    "$schema": "https://json-schema.org/draft-07/schema#",
    "title": "Schema for pack `manifest.json`",
    "type": "object",
    "required": ["formatVersion", "nameSpace", "uuid", "minEngineVersion", "version", "entryPoint"],
    "properties": {
        "formatVersion": {
            "type": "integer",
            "const": 1
        },
        "nameSpace": {
            "type": "string",
            "minLength": 1
        },
        "uuid": {
            "type": "string",
            "format": "uuid"
        },
        "minEngineVersion": {
            "type": "integer",
            "minimum": 1
        },
        "version": {
            "type": "integer",
            "minimum": 1
        },
        "entryPoint": {
            "type": "string",
            "minLength": 1
        },
        "name": {
            "type": "string",
            "default": "Content Pack",
            "minLength": 1
        },
        "description": {
            "type": "string",
            "default": "This content pack has no description."
        },
        "authors": {
            "type": "array",
            "uniqueItems": true,
            "minItems": 1,
            "items": {
                "type": "string",
                "minLength": 1
            },
            "default": []
        },
        "configs": {
            "type": "object",
            "properties": {
                "namespaceCollision": {
                    "type": "string",
                    "enum": ["ignore", "warn", "fail"],
                    "default": "warn"
                },
                "alwaysLoad": {
                    "type": "boolean",
                    "default": false
                },
                "licenseLibre": {
                    "type": "boolean",
                    "default": false
                },
                "allowDynamicCode": {
                    "type": "boolean",
                    "default": false
                }
            },
            "default": {
                "namespaceCollision": "warn",
                "alwaysLoad": false,
                "licenseLibre": false,
                "allowDynamicCode": false
            }
        },
        "dependencies": {
            "type": "object",
            "properties": {
                "mustBefore": {
                    "type": "array",
                    "uniqueItems": true,
                    "minItems": 1,
                    "items": {
                        "type": "object",
                        "required": ["uuid"],
                        "properties": {
                            "uuid": {
                                "type": "string",
                                "format": "uuid"
                            },
                            "minVersion": {
                                "type": "integer",
                                "minimum": 1,
                                "default": 0
                            },
                            "maxVersion": {
                                "type": "integer",
                                "minimum": 1,
                                "default": 0
                            }
                        }
                    },
                    "default": []
                },
                "optBefore": {
                    "type": "array",
                    "uniqueItems": true,
                    "minItems": 1,
                    "items": {
                        "type": "object",
                        "required": ["uuid"],
                        "properties": {
                            "uuid": {
                                "type": "string",
                                "format": "uuid"
                            },
                            "minVersion": {
                                "type": "integer",
                                "minimum": 1,
                                "default": 0
                            },
                            "maxVersion": {
                                "type": "integer",
                                "minimum": 1,
                                "default": 0
                            }
                        }
                    },
                    "default": []
                },
                "mustAfter": {
                    "type": "array",
                    "uniqueItems": true,
                    "minItems": 1,
                    "items": {
                        "type": "object",
                        "required": ["uuid"],
                        "properties": {
                            "uuid": {
                                "type": "string",
                                "format": "uuid"
                            },
                            "minVersion": {
                                "type": "integer",
                                "minimum": 1,
                                "default": 0
                            },
                            "maxVersion": {
                                "type": "integer",
                                "minimum": 1,
                                "default": 0
                            }
                        }
                    },
                    "default": []
                },
                "optAfter": {
                    "type": "array",
                    "uniqueItems": true,
                    "minItems": 1,
                    "items": {
                        "type": "object",
                        "required": ["uuid"],
                        "properties": {
                            "uuid": {
                                "type": "string",
                                "format": "uuid"
                            },
                            "minVersion": {
                                "type": "integer",
                                "minimum": 1,
                                "default": 0
                            },
                            "maxVersion": {
                                "type": "integer",
                                "minimum": 1,
                                "default": 0
                            }
                        }
                    },
                    "default": []
                },
                "mustAnyOrder": {
                    "type": "array",
                    "uniqueItems": true,
                    "minItems": 1,
                    "items": {
                        "type": "object",
                        "required": ["uuid"],
                        "properties": {
                            "uuid": {
                                "type": "string",
                                "format": "uuid"
                            },
                            "minVersion": {
                                "type": "integer",
                                "minimum": 1,
                                "default": 0
                            },
                            "maxVersion": {
                                "type": "integer",
                                "minimum": 1,
                                "default": 0
                            }
                        }
                    },
                    "default": []
                },
                "optAnyOrder": {
                    "type": "array",
                    "uniqueItems": true,
                    "minItems": 1,
                    "items": {
                        "type": "object",
                        "required": ["uuid"],
                        "properties": {
                            "uuid": {
                                "type": "string",
                                "format": "uuid"
                            },
                            "minVersion": {
                                "type": "integer",
                                "minimum": 1,
                                "default": 0
                            },
                            "maxVersion": {
                                "type": "integer",
                                "minimum": 1,
                                "default": 0
                            }
                        }
                    },
                    "default": []
                },
                "hardBreakers": {
                    "type": "array",
                    "uniqueItems": true,
                    "minItems": 1,
                    "items": {
                        "type": "object",
                        "required": ["uuid"],
                        "properties": {
                            "uuid": {
                                "type": "string",
                                "format": "uuid"
                            },
                            "minVersion": {
                                "type": "integer",
                                "minimum": 1,
                                "default": 0
                            },
                            "maxVersion": {
                                "type": "integer",
                                "minimum": 1,
                                "default": 0
                            }
                        }
                    },
                    "default": []
                },
                "softWarnings": {
                    "type": "array",
                    "uniqueItems": true,
                    "minItems": 1,
                    "items": {
                        "type": "object",
                        "required": ["uuid"],
                        "properties": {
                            "uuid": {
                                "type": "string",
                                "format": "uuid"
                            },
                            "minVersion": {
                                "type": "integer",
                                "minimum": 1,
                                "default": 0
                            },
                            "maxVersion": {
                                "type": "integer",
                                "minimum": 1,
                                "default": 0
                            }
                        }
                    }
                }
            },
            "default": {
                "mustBefore": [],
                "optBefore": [],
                "mustAfter": [],
                "optAfter": [],
                "mustAnyOrder": [],
                "optAnyOrder": [],
                "hardBreakers": [],
                "softWarnings": []
            }
        },
        "customOptions": {
            "type": "array",
            "uniqueItems": true,
            "minItems": 1,
            "items": {
                "type": "object",
                "required": ["identifier", "type", "default"],
                "properties": {
                    "identifier": {
                        "type": "string",
                        "minLength": 1
                    },
                    "type": {
                        "type": "string",
                        "enum": ["string", "integer", "float", "boolean"]
                    },
                    "default": {},
                    "min": {},
                    "max": {}
                },
                "allOf": [
                    {
                        "if": {
                            "required": ["type"],
                            "properties": { "type": { "const": "integer" }}
                        },
                        "then": {
                            "required": ["min", "max"],
                            "properties": {
                                "default": { "type": "integer" },
                                "min": { "type": "integer" },
                                "max": { "type": "integer" }
                            }
                        }
                    },
                    {
                        "if": {
                            "required": ["type"],
                            "properties": { "type": { "const": "float" }}
                        },
                        "then": {
                            "required": ["min", "max"],
                            "properties": {
                                "default": { "type": "number" },
                                "min": { "type": "number" },
                                "max": { "type": "number" }
                            }
                        }
                    },
                    {
                        "if": { "not": {
                            "required": ["type"],
                            "properties": { "type": { "enum": ["integer", "float"]}}
                        }},
                        "then": { "not": { "anyOf": [
                            {"required": ["min"]},
                            {"required": ["max"]}
                        ]}}
                    },
                    {
                        "if": {
                            "required": ["type"],
                            "properties": { "type": { "const": "string" }}
                        },
                        "then": { "properties": { "default": { "type": "string" }}}
                    },
                    {
                        "if": {
                            "required": ["type"],
                            "properties": { "type": { "const": "boolean" }}
                        },
                        "then": { "properties": { "default": { "type": "boolean" }}}
                    }
                ]
            },
            "default": []
        }
    }
}